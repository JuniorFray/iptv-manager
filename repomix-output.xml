@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --primary: #6366f1;
  --bg: #0a081e;
  --surface: #12103a;
  --border: rgba(255, 255, 255, 0.08);
}

* {
  box-sizing: border-box;
}

body {
  background: var(--bg);
  color: white;
  font-family: 'Inter', system-ui, sans-serif;
  margin: 0;
  padding: 0;
}

.glass {
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.glass-card {
  background: rgba(255, 255, 255, 0.04);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #6366f1);
  color: white;
  border: none;
  border-radius: 12px;
  padding: 12px 24px;
  font-weight: bold;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(99, 102, 241, 0.6);
}

.input-glass {
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 12px;
  color: white;
  padding: 12px 16px;
  width: 100%;
  outline: none;
  transition: all 0.3s ease;
  font-size: 14px;
}

.input-glass:focus {
  border-color: rgba(99, 102, 241, 0.8);
  box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
  background: rgba(255, 255, 255, 0.12);
}

.input-glass::placeholder {
  color: rgba(255, 255, 255, 0.35);
}

/* ===== LAYOUT RESPONSIVO ===== */

.sidebar-desktop {
  display: flex !important;
}

.bottom-nav-mobile {
  display: none !important;
}

.mobile-header {
  display: none !important;
}

.main-content {
  margin-left: 176px;
  padding: 32px;
  min-height: 100vh;
}

.table-responsive {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

/* ===== MEDIA QUERY MOBILE ===== */

@media (max-width: 768px) {
  /* Layout */
  .sidebar-desktop { display: none !important; }
  .bottom-nav-mobile { display: flex !important; }
  .mobile-header { display: flex !important; }
  .hide-mobile { display: none !important; }

  .main-content {
    margin-left: 0 !important;
    padding: 12px !important;
    padding-top: 68px !important;
    padding-bottom: 80px !important;
    width: 100% !important;
    overflow-x: hidden !important;
  }

  /* Typography */
  .page-title { font-size: 20px !important; }

  /* Headers das páginas */
  .page-header {
    flex-direction: column !important;
    align-items: stretch !important;
    gap: 10px !important;
  }

  .page-header-actions {
    width: 100% !important;
    flex-wrap: wrap !important;
    gap: 8px !important;
  }

  .page-header-actions button {
    flex: 1 !important;
    min-width: 100px !important;
    justify-content: center !important;
    font-size: 12px !important;
    padding: 10px 8px !important;
  }

  /* Cards do Dashboard */
  .dashboard-cards {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 10px !important;
  }

  .dashboard-card {
    padding: 16px !important;
  }

  .dashboard-card .card-value {
    font-size: 22px !important;
  }

  /* Tabela de clientes — card list no mobile */
  .clientes-table-wrap { display: none !important; }
  .clientes-cards-mobile { display: flex !important; }

  /* Cards de cliente no mobile */
  .cliente-card-mobile {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 14px;
    margin-bottom: 10px;
  }

  .cliente-card-mobile .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 6px;
