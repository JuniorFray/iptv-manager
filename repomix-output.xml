                    {filtrados.map(p => (
                      <tr key={p.id} style={{ borderBottom: '1px solid rgba(255,255,255,0.05)' }}>
                        <td style={{ padding: '12px', color: 'white', fontSize: '13px' }}>
                          <div style={{ fontWeight: '600' }}>{p.clienteNome}</div>
