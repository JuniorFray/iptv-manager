                            <button onClick={() => toggleCupom(c.codigo)} style={{ padding: '4px 8px', borderRadius: '6px', cursor: 'pointer', background: 'rgba(255,255,255,0.06)', border: '1px solid rgba(255,255,255,0.1)', color: 'rgba(255,255,255,0.5)' }}>
