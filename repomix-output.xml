          </div>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '14px' }}>
            {[
              { label: 'IPTV', value: iptv, color: '#60a5fa', bg: 'rgba(59,130,246,0.3)' },
              { label: 'P2P',  value: p2p,  color: '#c084fc', bg: 'rgba(168,85,247,0.3)' },
