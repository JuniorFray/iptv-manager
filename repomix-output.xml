              </div>
              {modoEnquete && (
                <div style={{ display: 'flex', flexDirection: 'column', gap: '10px', marginBottom: '12px' }}>
                  <input value={enqueteTitulo} onChange={e => setEnqueteTitulo(e.target.value)} placeholder="Título da enquete (ex: Qual plano você prefere?)"
